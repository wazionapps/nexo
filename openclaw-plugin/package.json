{
  "name": "@wazionapps/openclaw-memory-nexo-brain",
  "version": "7.38.7",
  "description": "OpenClaw memory plugin powered by the NEXO Desktop runtime core: local memory, Deep Sleep, Evolution support-ticket mode, trust scoring, and guarded continuity.",
  "type": "module",
  "main": "dist/index.js",
  "exports": "./dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "node --test tests/*.test.mjs",
    "prepack": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist/",
    "openclaw.plugin.json",
    "README.md",
    "package.json"
  ],
  "dependencies": {
    "@sinclair/typebox": "^0.34.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.7.0"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "install": {
      "npmSpec": "@wazionapps/openclaw-memory-nexo-brain",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.3.0"
    },
    "release": {
      "publishToNpm": true
    }
  },
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "memory",
    "cognitive",
    "nexo",
    "mcp",
    "ai-memory",
    "vector-search"
  ],
  "author": "WAzion Apps <info@wazion.com>",
  "license": "AGPL-3.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wazionapps/nexo.git",
    "directory": "openclaw-plugin"
  },
  "homepage": "https://nexo-desktop.com"
}
