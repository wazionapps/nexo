{
  "$schema": "https://nexo-brain.com/schemas/guardian-config-v1.json",
  "version": "1.3.3",
  "description": "Default Guardian configuration. Copied to ~/.nexo/config/guardian.json at `nexo init` / `nexo update` if no user config exists. If user config exists, merge keys NOT present in user config without overwriting user overrides. Core rules (R13, R14, R16, R25, R30) can only be shadow/soft/hard — mode=off is rejected by validator.",
  "enabled": true,
  "classifier_task_profile": "enforcer_classify",
  "classifier_tier": "muy_bajo",
  "sentiment_correction_threshold": 0.4,
  "telemetry": {
    "local_enabled": true,
    "local_path": "~/.nexo/logs/guardian-telemetry.ndjson",
    "external_optin": false,
    "note": "Local telemetry always ON (fuels auto-tuning of rule modes via Fase F). External upload is opt-in only."
  },
  "rules": {
    "R01_followup_create_dedup": "hard",
    "R02_credential_create_dedup": "soft",
    "R03_task_close_evidence": "hard",
    "R04_followup_complete_retroactive": "soft",
    "R05_learning_add_dedup": "hard",
    "R06_email_send_secret_filter": "hard",
    "R07_memory_recall_age_flag": "soft",
    "R08_reminder_recurrence_conflict": "soft",
    "R09_artifact_create_dedup": "soft",
    "R10_workflow_open_without_task": "hard",
    "R11_plugin_load_pre_inventory": "soft",
    "R12_cognitive_write_dedup": "soft",
    "R13_pre_edit_guard": "hard",
    "R14_correction_learning": "hard",
    "R15_project_context": "soft",
    "R16_declared_done": "hard",
    "R17_promise_debt": "soft",
    "R18_followup_autocomplete": "soft",
    "R19_project_grep": "soft",
    "R20_constant_grep": "soft",
    "R21_legacy_path": "shadow",
    "R22_personal_script": "soft",
    "R23_ssh_without_atlas": "soft",
    "R23i_auto_deploy_ignored": "soft",
    "R23j_global_install": "shadow",
    "R23k_script_duplicates_skill": "soft",
    "R24_stale_memory": "shadow",
    "R25_nora_maria_read_only": "hard",
    "R30_pre_done_evidence_system_prompt": "hard",
    "R_CATALOG_before_artifact_create": "soft",
    "R26_no_internal_jargon": "hard",
    "R27_concise_responses": "hard",
    "R28_correction_learning_system_prompt": "hard",
    "R29_no_unexecuted_promises": "hard",
    "R31_no_assumptions_servers": "hard",
    "R32_nora_maria_read_only_system_prompt": "hard",
    "R33_procedure_lookup": "hard",
    "R23b_deploy_vhost": "hard",
    "R23e_force_push_main": "hard",
    "R23f_db_no_where": "hard",
    "R23l_resource_collision": "hard",
    "R23c_cwd_mismatch": "soft",
    "R23d_chown_chmod_recursive": "soft",
    "R23g_secrets_in_output": "soft",
    "R23m_message_duplicate": "soft",
    "R23h_shebang_mismatch": "shadow",
    "R34_identity_coherence": "shadow"
  },
  "core_rules": [
    "R13_pre_edit_guard",
    "R14_correction_learning",
    "R16_declared_done",
    "R25_nora_maria_read_only",
    "R30_pre_done_evidence_system_prompt"
  ],
  "fail_closed": {
    "classifier_timeout_seconds": 10,
    "classifier_timeout_action": "inject_generic_reminder",
    "rate_limit_action": "retry_once_then_inject_reminder",
    "backend_5xx_action": "degrade_rule_to_shadow_for_session",
    "connection_error_action": "inject_generic_reminder",
    "note": "Never fail-open. Silence is not obedience. Rule #249: structured protocol inputs must fail explicitly, never coerce silently."
  },
  "dedup": {
    "injection_window_seconds": 60,
    "max_pending_injections": 5
  },
  "runtime_overrides": {
    "enabled": true,
    "path": "~/.nexo/config/guardian-runtime-overrides.json",
    "note": "Written by nexo_guardian_rule_override. Read at start of every turn by Desktop wrapper + headless enforcer + MCP server. No restart required."
  }
}
