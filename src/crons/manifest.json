{
  "$schema": "NEXO cron manifest — synced by nexo_update to LaunchAgents (macOS) or systemd timers (Linux)",
  "version": 2,
  "crons": [
    {
      "id": "deep-sleep",
      "script": "scripts/nexo-deep-sleep.sh",
      "type": "shell",
      "schedule": {"hour": 4, "minute": 30},
      "description": "Overnight session analysis — 4 phases: collect, extract, synthesize, apply",
      "core": true,
      "optional": "automation",
      "recovery_policy": "catchup",
      "idempotent": true,
      "max_catchup_age": 172800,
      "run_on_boot": true,
      "run_on_wake": true
    },
    {
      "id": "cortex-cycle",
      "script": "scripts/nexo-cortex-cycle.py",
      "interval_seconds": 21600,
      "description": "Continuous Cortex quality validation — every 6h. Persists snapshot and opens NF-CORTEX-QUALITY-DROP followup on degradation",
      "core": true,
      "recovery_policy": "catchup",
      "idempotent": true,
      "max_catchup_age": 86400,
      "run_on_boot": false,
      "run_on_wake": false
    },
    {
      "id": "sleep",
      "script": "scripts/nexo-sleep.py",
      "schedule": {"hour": 4, "minute": 0},
      "description": "Nightly memory consolidation and dream cycle",
      "core": true,
      "optional": "automation",
      "recovery_policy": "catchup",
      "idempotent": true,
      "max_catchup_age": 172800,
      "run_on_boot": true,
      "run_on_wake": true
    },
    {
      "id": "cognitive-decay",
      "script": "scripts/nexo-cognitive-decay.py",
      "schedule": {"hour": 3, "minute": 0},
      "description": "Memory decay — reduce strength of unaccessed memories",
      "core": true,
      "recovery_policy": "catchup",
      "idempotent": true,
      "max_catchup_age": 172800,
      "run_on_boot": true,
      "run_on_wake": true
    },
    {
      "id": "learning-housekeep",
      "script": "scripts/nexo-learning-housekeep.py",
      "schedule": {"hour": 3, "minute": 15},
      "description": "Archive stale learnings, deduplicate, validate",
      "core": true,
      "recovery_policy": "catchup",
      "idempotent": true,
      "max_catchup_age": 172800,
      "run_on_boot": true,
      "run_on_wake": true
    },
    {
      "id": "immune",
      "script": "scripts/nexo-immune.py",
      "interval_seconds": 1800,
      "description": "Health monitor — checks MCP, DB, services, auto-repairs",
      "core": true,
      "recovery_policy": "restart",
      "idempotent": true,
      "max_catchup_age": 7200,
      "run_on_boot": true,
      "run_on_wake": true
    },
    {
      "id": "watchdog",
      "script": "scripts/nexo-watchdog.sh",
      "type": "shell",
      "interval_seconds": 1800,
      "description": "System health checks — snapshots, logs, alerts",
      "core": true,
      "recovery_policy": "restart",
      "idempotent": true,
      "max_catchup_age": 7200,
      "run_on_boot": true,
      "run_on_wake": true
    },
    {
      "id": "self-audit",
      "script": "scripts/nexo-daily-self-audit.py",
      "schedule": {"hour": 7, "minute": 0},
      "description": "Daily self-audit — validates learnings, protocols, drift",
      "core": true,
      "optional": "automation",
      "recovery_policy": "catchup",
      "idempotent": true,
      "max_catchup_age": 172800,
      "run_on_boot": true,
      "run_on_wake": true
    },
    {
      "id": "postmortem",
      "script": "scripts/nexo-postmortem-consolidator.py",
      "schedule": {"hour": 23, "minute": 30},
      "description": "Consolidate session post-mortems into patterns",
      "core": true,
      "optional": "automation",
      "recovery_policy": "catchup",
      "idempotent": true,
      "max_catchup_age": 172800,
      "run_on_boot": true,
      "run_on_wake": true
    },
    {
      "id": "evolution",
      "script": "scripts/nexo-evolution-run.py",
      "schedule_strategy": "machine_weekly_spread",
      "schedule": {"hour": 5, "minute": 0, "weekday": 0},
      "description": "Weekly self-improvement cycle — propose and evaluate changes",
      "core": true,
      "optional": "automation",
      "recovery_policy": "catchup",
      "idempotent": true,
      "max_catchup_age": 1209600,
      "run_on_boot": true,
      "run_on_wake": true
    },
    {
      "id": "followup-hygiene",
      "script": "scripts/nexo-followup-hygiene.py",
      "schedule": {"hour": 5, "minute": 0, "weekday": 0},
      "description": "Clean stale followups, archive completed, validate dates",
      "core": true,
      "recovery_policy": "catchup",
      "idempotent": true,
      "max_catchup_age": 1209600,
      "run_on_boot": true,
      "run_on_wake": true
    },
    {
      "id": "synthesis",
      "script": "scripts/nexo-synthesis.py",
      "schedule": {"hour": 6, "minute": 0},
      "description": "Daily synthesis — cross-reference learnings, decisions, changes",
      "core": true,
      "optional": "automation",
      "recovery_policy": "catchup",
      "idempotent": true,
      "max_catchup_age": 172800,
      "run_on_boot": true,
      "run_on_wake": true
    },
    {
      "id": "impact-scorer",
      "script": "scripts/nexo-impact-scorer.py",
      "schedule": {"hour": 5, "minute": 45},
      "description": "Daily impact scoring for active followups so real queues can prioritize by expected impact",
      "core": true,
      "recovery_policy": "catchup",
      "idempotent": true,
      "max_catchup_age": 172800,
      "run_on_boot": true,
      "run_on_wake": true
    },
    {
      "id": "outcome-checker",
      "script": "scripts/nexo-outcome-checker.py",
      "schedule": {"hour": 8, "minute": 0},
      "description": "Daily outcome verification — marks tracked outcomes as met or missed",
      "core": true,
      "recovery_policy": "catchup",
      "idempotent": true,
      "max_catchup_age": 172800,
      "run_on_boot": true,
      "run_on_wake": true
    },
    {
      "id": "auto-close-sessions",
      "script": "auto_close_sessions.py",
      "interval_seconds": 300,
      "description": "Close stale sessions that lost their parent process",
      "core": true,
      "recovery_policy": "restart",
      "idempotent": true,
      "max_catchup_age": 1800,
      "run_on_boot": true,
      "run_on_wake": true
    },
    {
      "id": "catchup",
      "script": "scripts/nexo-catchup.py",
      "interval_seconds": 900,
      "run_at_load": true,
      "description": "Morning catchup briefing for the user",
      "core": true,
      "recovery_policy": "none",
      "idempotent": true,
      "max_catchup_age": 0,
      "run_on_boot": true,
      "run_on_wake": true
    },
    {
      "id": "auto-update",
      "script": "scripts/nexo-auto-update.py",
      "schedule": {"hour": 2, "minute": 0},
      "description": "Daily auto-update — Brain + runtime dependencies",
      "core": true,
      "recovery_policy": "catchup",
      "idempotent": true,
      "max_catchup_age": 172800,
      "run_on_boot": true,
      "run_on_wake": true
    }
  ]
}
